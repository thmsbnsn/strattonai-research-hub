{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strattonai.local/schemas/n8n_targeted_research_template.schema.json",
  "title": "StrattonAI n8n Targeted Research Template",
  "type": "object",
  "required": [
    "template_metadata",
    "workflow_contract",
    "research_slices"
  ],
  "properties": {
    "template_metadata": {
      "type": "object",
      "required": [
        "template_name",
        "schema_version",
        "template_only",
        "purpose",
        "generated_from_plan_path"
      ],
      "properties": {
        "template_name": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "template_only": {
          "type": "boolean"
        },
        "purpose": {
          "type": "string"
        },
        "generated_from_plan_path": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "workflow_contract": {
      "type": "object",
      "required": [
        "source_of_truth",
        "n8n_role",
        "review_gate",
        "handoff_targets"
      ],
      "properties": {
        "source_of_truth": {
          "type": "string"
        },
        "n8n_role": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_gate": {
          "type": "string"
        },
        "handoff_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "research_slices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/researchSlice"
      }
    }
  },
  "$defs": {
    "searchQuery": {
      "type": "object",
      "required": [
        "query_text",
        "source_type",
        "priority",
        "notes"
      ],
      "properties": {
        "query_text": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "market-events",
            "sec-filings",
            "press-release",
            "company-ir",
            "major-news",
            "exchange-announcement",
            "regulator-release",
            "price-history",
            "company-profile",
            "other"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "sourceCandidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "source_type",
        "source_name",
        "source_url",
        "retrieval_status",
        "notes"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string"
        },
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "retrieval_status": {
          "type": "string",
          "enum": [
            "pending_fetch",
            "fetched",
            "rejected",
            "error"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "relatedCompany": {
      "type": "object",
      "required": [
        "ticker",
        "name",
        "relationship"
      ],
      "properties": {
        "ticker": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "relationship": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "collectedExample": {
      "type": "object",
      "required": [
        "source_name",
        "source_record_id",
        "source_url",
        "source_title",
        "source_publisher",
        "published_at",
        "occurred_at",
        "headline",
        "summary",
        "primary_ticker",
        "related_companies",
        "event_type_hint",
        "sentiment_hint",
        "relationship_evidence",
        "extraction_notes",
        "evidence_quote",
        "evidence_confidence",
        "duplicate_check_key",
        "ready_for_ingestion"
      ],
      "properties": {
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_record_id": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "source_title": {
          "type": "string"
        },
        "source_publisher": {
          "type": "string"
        },
        "published_at": {
          "type": "string"
        },
        "occurred_at": {
          "type": "string"
        },
        "headline": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "primary_ticker": {
          "type": "string",
          "minLength": 1
        },
        "related_companies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relatedCompany"
          }
        },
        "event_type_hint": {
          "type": "string"
        },
        "sentiment_hint": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "neutral",
            "mixed",
            "unknown"
          ]
        },
        "relationship_evidence": {
          "type": [
            "string",
            "null"
          ]
        },
        "extraction_notes": {
          "type": "string"
        },
        "evidence_quote": {
          "type": "string"
        },
        "evidence_confidence": {
          "type": "string",
          "enum": [
            "unrated",
            "low",
            "medium",
            "high"
          ]
        },
        "duplicate_check_key": {
          "type": "string",
          "minLength": 1
        },
        "ready_for_ingestion": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "researchSlice": {
      "type": "object",
      "required": [
        "placeholder_example",
        "source_gap_key",
        "priority_rank",
        "priority_score",
        "gap_score",
        "event_category",
        "target_type",
        "primary_ticker",
        "related_ticker",
        "relationship_type",
        "desired_sample_count",
        "current_sample_count",
        "gap_size",
        "why_this_slice_matters",
        "suggested_source_type",
        "suggested_source_priority",
        "search_queries",
        "source_candidates",
        "collected_examples",
        "review_status",
        "reviewer_notes"
      ],
      "properties": {
        "placeholder_example": {
          "type": "boolean"
        },
        "source_gap_key": {
          "type": "string",
          "minLength": 1
        },
        "priority_rank": {
          "type": "integer",
          "minimum": 1
        },
        "priority_score": {
          "type": "number"
        },
        "gap_score": {
          "type": "number"
        },
        "event_category": {
          "type": "string",
          "minLength": 1
        },
        "target_type": {
          "type": "string",
          "enum": [
            "primary_exact",
            "related_company",
            "relationship_slice",
            "price_gap",
            "category_balance",
            "other"
          ]
        },
        "primary_ticker": {
          "type": [
            "string",
            "null"
          ]
        },
        "related_ticker": {
          "type": [
            "string",
            "null"
          ]
        },
        "relationship_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "desired_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "current_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "gap_size": {
          "type": "integer",
          "minimum": 0
        },
        "why_this_slice_matters": {
          "type": "string",
          "minLength": 1
        },
        "suggested_source_type": {
          "type": "string",
          "enum": [
            "market-events",
            "sec-filings",
            "company-profile",
            "price-history",
            "mixed",
            "other"
          ]
        },
        "suggested_source_priority": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "search_queries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/searchQuery"
          }
        },
        "source_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceCandidate"
          }
        },
        "collected_examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/collectedExample"
          }
        },
        "review_status": {
          "type": "string",
          "enum": [
            "pending_research",
            "research_in_progress",
            "pending_review",
            "needs_more_research",
            "approved_for_ingestion",
            "rejected",
            "ingested"
          ]
        },
        "reviewer_notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
